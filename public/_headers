# Cloudflare Pages cache policy.
# Copied verbatim into out/_headers by Next's static export (anything in public/
# ends up at the root of the deploy).
#
# Rules are matched top-to-bottom; the first match wins per header name, then
# Cloudflare merges with downstream defaults. We make HTML never stick in cache
# (so soft reloads always pick up new deploys) and let content-hashed assets be
# immutable.

# Content-hashed Next.js assets — safe to cache forever, the hash IS the version.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts and SMuFL files — versioned by filename in our repo.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Root HTML and any other directly-served page — must revalidate every time so
# a new deploy is picked up without a hard reload.
/
  Cache-Control: no-store, must-revalidate
  X-Content-Type-Options: nosniff

/index.html
  Cache-Control: no-store, must-revalidate

/*.html
  Cache-Control: no-store, must-revalidate

# Everything else under the root gets a short cache with revalidation as a
# sensible default. Specific routes above override.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
